# Copy to .env, fill in, source before running the workers.

# Required: OpenRouter API key for the cheap advisor pool.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: where the local SQLite task queue lives.
# Defaults to ~/.local/share/relay-drones/queue.db
# RELAY_DRONES_DB=/path/to/queue.db

# Optional: artifact + log directory.
# Defaults to <repo>/artifacts and <repo>/logs
# RELAY_DRONES_ARTIFACTS=/path/to/artifacts
# RELAY_DRONES_LOGS=/path/to/logs

# Optional: tune the handoff guards.
# RELAY_DRONES_MAX_CLAUDE_RUNS_PER_DAY=40
# RELAY_DRONES_MAX_HANDOFF_DEPTH=2
# RELAY_DRONES_HANDOFF_MODEL=claude-sonnet-4-6
# RELAY_DRONES_HANDOFF_TIMEOUT=600

# DO NOT set ANTHROPIC_API_KEY here if you want to use the Max subscription.
# If you set it, Claude Code will prefer the API key and bill per-token.
# The worker strips this var from the subprocess env before invoking
# `claude -p`, so even if your shell exports it, the handoff still uses
# OAuth. See docs/oauth-trick.md.

# ─── notify_human backends ───────────────────────────────────────────────
# At least one of these enables the notify_human action_kind. When the
# cheap advisor decides a problem is too risky / unclear for the system
# to fix on its own, the worker calls notify.send() to ping you instead.
# All configured backends fire (Telegram + ntfy + webhook) so the message
# goes through whichever is fastest.

# Telegram bot — make one at @BotFather. chat_id is the destination user/group.
# RELAY_DRONES_NOTIFY_TELEGRAM_BOT_TOKEN=1234567890:ABC...
# RELAY_DRONES_NOTIFY_TELEGRAM_CHAT_ID=1032451690

# ntfy.sh push notifications. Subscribe to <topic> on the ntfy app to receive.
# Use a random unguessable topic name — anyone who knows it can send you spam.
# RELAY_DRONES_NOTIFY_NTFY_TOPIC=my-secret-topic-xyz
# RELAY_DRONES_NOTIFY_NTFY_SERVER=https://ntfy.sh   # override for self-hosted

# Generic webhook — POSTs {title, body, source} JSON. Wire to Slack/Discord/n8n.
# RELAY_DRONES_NOTIFY_WEBHOOK_URL=https://hooks.example.com/incoming/abc

# ─── action_kind allowlist tuning ────────────────────────────────────────
# By default the worker accepts these action_kinds for escalation:
#   tail_log, config_inspect, dns_repair, cron_disable, service_health,
#   restart_launchagent, notify_human, config_edit_proposed, pr_open
# Tighten by setting an explicit list; remove any kind you don't want enabled.
# RELAY_DRONES_ACTION_ALLOWLIST=tail_log,config_inspect,notify_human

# Daily Claude handoff cap (notify_human is NOT counted — it doesn't spawn Claude).
# RELAY_DRONES_MAX_CLAUDE_RUNS_PER_DAY=40

# Max chain depth before refusal. Lower is safer; higher allows longer
# self-prompt → action → self-prompt chains.
# RELAY_DRONES_MAX_HANDOFF_DEPTH=2
